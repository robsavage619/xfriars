<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ article.title }}{% if article.subtitle %} — {{ article.subtitle }}{% endif %}</title>
{% if article.dek %}<meta name="description" content="{{ article.dek }}">{% endif %}
<meta name="author" content="{{ article.author }}">
<link rel="canonical" href="{{ canonical }}">
<meta property="og:type" content="article">
<meta property="og:title" content="{{ article.title }}">
{% if article.dek %}<meta property="og:description" content="{{ article.dek }}">{% endif %}
<meta property="og:url" content="{{ public_url }}">
{% if og_image %}<meta property="og:image" content="{{ og_image }}">{% endif %}
<meta name="twitter:card" content="summary_large_image">
{% if article.date %}<meta property="article:published_time" content="{{ article.date }}">{% endif %}
{% for tag in article.tags %}<meta property="article:tag" content="{{ tag }}">{% endfor %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;700;800;900&family=Space+Grotesk:wght@400;500;600;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet">
<style>
  :root {
    --paper: #F4F1EA; --paper-panel: #ECE6DB; --ink: #1C1714; --ink-soft: #5A4636;
    --brown: #4A3526; --brown-dim: #8A6A4A; --gold: #C99A2E; --hot: #C0392B;
    --slate: #2C6E7F; --muted: #9A8E80; --hairline: rgba(28,23,20,0.12);
  }
  * { box-sizing: border-box; }
  html { -webkit-text-size-adjust: 100%; }
  body {
    margin: 0; background: var(--paper); color: var(--ink);
    font-family: "Newsreader", Georgia, serif;
    font-size: 20px; line-height: 1.62; -webkit-font-smoothing: antialiased;
  }
  .wrap { max-width: 720px; margin: 0 auto; padding: 0 24px 96px; }
  .topbar { max-width: 720px; margin: 0 auto; padding: 28px 24px 0; display: flex; justify-content: space-between; align-items: center; }
  .brand { font-family: "Space Grotesk", sans-serif; font-weight: 700; font-size: 14px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--brown); }
  .brand .friars { color: var(--gold); }

  header.article-head { padding-top: 40px; }
  .kicker { font-family: "Space Grotesk", sans-serif; font-weight: 600; font-size: 13px; letter-spacing: 0.24em; text-transform: uppercase; color: var(--brown-dim); margin-bottom: 18px; }
  h1.title { font-family: "Big Shoulders Display", sans-serif; font-weight: 800; font-size: 60px; line-height: 0.96; letter-spacing: 0.005em; margin: 0 0 16px; text-transform: uppercase; }
  .subtitle { font-family: "Space Grotesk", sans-serif; font-weight: 500; font-size: 22px; line-height: 1.3; color: var(--ink-soft); margin: 0 0 24px; }
  .dek { font-size: 22px; line-height: 1.5; color: var(--ink-soft); font-style: italic; border-left: 3px solid var(--gold); padding-left: 20px; margin: 0 0 28px; }
  .byline { font-family: "Space Grotesk", sans-serif; font-size: 14px; letter-spacing: 0.04em; color: var(--muted); display: flex; gap: 10px; align-items: center; flex-wrap: wrap; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); padding: 14px 0; margin-bottom: 8px; }
  .byline b { color: var(--ink); font-weight: 600; }
  .byline .dot { color: var(--hairline); }

  .hero { margin: 32px 0 8px; }
  .hero img { width: 100%; height: auto; border-radius: 8px; display: block; }

  .content { margin-top: 36px; }
  .content p { margin: 0 0 24px; }
  .content a { color: var(--hot); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
  .content h2 { font-family: "Big Shoulders Display", sans-serif; font-weight: 700; font-size: 34px; line-height: 1.04; text-transform: uppercase; letter-spacing: 0.01em; margin: 52px 0 16px; }
  .content h3 { font-family: "Space Grotesk", sans-serif; font-weight: 600; font-size: 22px; margin: 40px 0 12px; }
  .content blockquote { margin: 32px 0; padding: 4px 0 4px 24px; border-left: 3px solid var(--brown-dim); font-style: italic; color: var(--ink-soft); font-size: 24px; line-height: 1.45; }
  .content ul, .content ol { margin: 0 0 24px; padding-left: 28px; }
  .content li { margin-bottom: 8px; }
  .content strong { font-weight: 600; }
  .content hr { border: none; border-top: 1px solid var(--hairline); margin: 48px 0; }
  .content code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-size: 0.85em; background: var(--paper-panel); padding: 2px 6px; border-radius: 4px; }

  /* Figures break out wider than the reading column */
  figure.fig { margin: 44px -80px; }
  figure.fig img { width: 100%; height: auto; display: block; border-radius: 8px; }
  figure.fig figcaption { font-family: "Space Grotesk", sans-serif; font-size: 14px; line-height: 1.45; color: var(--muted); margin-top: 12px; padding: 0 4px; }
  figure.fig .fig-title { color: var(--ink); font-weight: 600; }
  figure.fig .fig-source { color: var(--brown-dim); }

  figure.fig-table { overflow-x: auto; }
  figure.fig-table table { width: 100%; border-collapse: collapse; font-family: "Space Grotesk", sans-serif; font-size: 16px; font-variant-numeric: tabular-nums; }
  figure.fig-table th { text-align: left; font-weight: 600; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--brown-dim); padding: 10px 14px; border-bottom: 2px solid var(--ink-soft); }
  figure.fig-table td { padding: 10px 14px; border-bottom: 1px solid var(--hairline); }
  figure.fig-table tr.hl { background: #F3E7CB; }
  figure.fig-table tr.hl td { font-weight: 600; }

  footer.article-foot { margin-top: 64px; padding-top: 24px; border-top: 1px solid var(--hairline); font-family: "Space Grotesk", sans-serif; font-size: 13px; letter-spacing: 0.06em; color: var(--muted); }
  footer .tag { text-transform: uppercase; letter-spacing: 0.16em; }
  footer .tag .friars { color: var(--gold); font-weight: 600; }
  .tags { margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap; }
  .tags span { background: var(--paper-panel); border-radius: 999px; padding: 4px 12px; font-size: 12px; color: var(--ink-soft); }

  @media (max-width: 820px) {
    h1.title { font-size: 44px; }
    figure.fig { margin: 36px 0; }
    body { font-size: 18px; }
  }
</style>
</head>
<body>
  <div class="topbar">
    <span class="brand">San Diego <span class="friars">·</span> Baseball Intelligence</span>
    <span class="brand friars">@xFriars</span>
  </div>

  <div class="wrap">
    <header class="article-head">
      <div class="kicker">San Diego Padres · Deep Dive</div>
      <h1 class="title">{{ article.title }}</h1>
      {% if article.subtitle %}<p class="subtitle">{{ article.subtitle }}</p>{% endif %}
      {% if article.dek %}<p class="dek">{{ article.dek }}</p>{% endif %}
      <div class="byline">
        <span>By <b>{{ article.author }}</b></span>
        {% if article.date %}<span class="dot">•</span><span>{{ article.date }}</span>{% endif %}
        <span class="dot">•</span><span>{{ reading_minutes }} min read</span>
      </div>
    </header>

    {% if hero_rel %}<div class="hero"><img src="{{ hero_rel }}" alt="{{ article.title }}"></div>{% endif %}

    <div class="content">
      {{ body_html }}
    </div>

    <footer class="article-foot">
      {% if article.tags %}<div class="tags">{% for tag in article.tags %}<span>{{ tag }}</span>{% endfor %}</div>{% endif %}
      <p class="tag" style="margin-top:18px"><span class="friars">@xFriars</span> · San Diego Baseball Intelligence</p>
    </footer>
  </div>
</body>
</html>
