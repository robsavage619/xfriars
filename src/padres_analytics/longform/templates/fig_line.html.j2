<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<script src="file://{{ d3_js }}"></script>
<style>
@font-face { font-family: "Space Grotesk"; src: url("file://{{ space_grotesk_ttf }}") format("truetype"); font-weight: 100 900; }
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { width: 1040px; height: 560px; overflow: hidden; background: {{ paper }}; font-family: "Space Grotesk", sans-serif; }
#fig { width: 1040px; height: 560px; }
</style>
</head>
<body>
<div id="fig"></div>
<div id="chart-ready" style="display:none"></div>
<script>
(function () {
  const S = {{ spec | safe }};
  const W = 1040, H = 560;
  const m = { t: 28, r: 120, b: 64, l: 78 };
  const iw = W - m.l - m.r, ih = H - m.t - m.b;
  const PALETTE = ["{{ hot }}", "{{ slate }}", "{{ gold }}", "{{ brown_dim }}"];

  // normalize to a list of series
  let series;
  if (S.series && S.series.length) {
    series = S.series.map(s => ({ name: s.name, pts: s.x.map((xv, i) => ({ x: xv, y: +s.y[i] })) }));
  } else {
    series = [{ name: "", pts: S.x.map((xv, i) => ({ x: xv, y: +S.y[i] })) }];
  }

  // x can be numeric or categorical; detect.
  const allX = series.flatMap(s => s.pts.map(p => p.x));
  const numericX = allX.every(v => typeof v === "number" || (!isNaN(parseFloat(v)) && isFinite(v)));
  const svg = d3.select("#fig").append("svg").attr("width", W).attr("height", H);
  const g = svg.append("g").attr("transform", `translate(${m.l},${m.t})`);

  let X;
  if (numericX) {
    const xs = allX.map(Number);
    X = d3.scaleLinear().domain([d3.min(xs), d3.max(xs)]).range([0, iw]);
    series.forEach(s => s.pts.forEach(p => p.x = +p.x));
  } else {
    const cats = series[0].pts.map(p => String(p.x));
    X = d3.scalePoint().domain(cats).range([0, iw]);
    series.forEach(s => s.pts.forEach(p => p.x = String(p.x)));
  }

  const ys = series.flatMap(s => s.pts.map(p => p.y));
  const pad = (d3.max(ys) - d3.min(ys)) * 0.12 || 1;
  const Y = d3.scaleLinear().domain([d3.min(ys) - pad, d3.max(ys) + pad]).nice().range([ih, 0]);

  // gridlines + y ticks
  Y.ticks(5).forEach(t => {
    g.append("line").attr("x1", 0).attr("x2", iw).attr("y1", Y(t)).attr("y2", Y(t))
      .attr("stroke", "{{ hairline }}").attr("stroke-width", 1);
    g.append("text").attr("x", -12).attr("y", Y(t) + 4).attr("text-anchor", "end")
      .attr("font-size", 14).attr("fill", "{{ text_muted }}").attr("font-variant-numeric", "tabular-nums")
      .text(d3.format("~g")(t));
  });

  // x ticks
  const xticks = numericX ? X.ticks(6) : X.domain();
  xticks.forEach(t => {
    g.append("text").attr("x", X(t)).attr("y", ih + 28).attr("text-anchor", "middle")
      .attr("font-size", 14).attr("fill", "{{ text_muted }}").attr("font-variant-numeric", "tabular-nums")
      .text(numericX ? d3.format("~g")(t) : t);
  });

  // axes
  g.append("line").attr("x1", 0).attr("x2", iw).attr("y1", ih).attr("y2", ih)
    .attr("stroke", "{{ ink_soft }}").attr("stroke-width", 1.2);

  const line = d3.line().x(d => X(d.x)).y(d => Y(d.y)).curve(d3.curveMonotoneX);
  series.forEach((s, i) => {
    const col = PALETTE[i % PALETTE.length];
    g.append("path").datum(s.pts).attr("d", line).attr("fill", "none")
      .attr("stroke", col).attr("stroke-width", 3);
    // end dot + inline label
    const last = s.pts[s.pts.length - 1];
    g.append("circle").attr("cx", X(last.x)).attr("cy", Y(last.y)).attr("r", 5)
      .attr("fill", col).attr("stroke", "{{ paper }}").attr("stroke-width", 1.5);
    if (s.name) {
      g.append("text").attr("x", X(last.x) + 12).attr("y", Y(last.y) + 4)
        .attr("font-size", 15).attr("font-weight", 600).attr("fill", col).text(s.name);
    }
  });

  if (S.y_label) {
    svg.append("text").attr("transform", `translate(20, ${m.t + ih / 2}) rotate(-90)`)
      .attr("text-anchor", "middle").attr("font-size", 14).attr("letter-spacing", "0.12em")
      .attr("fill", "{{ brown_dim }}").text(S.y_label.toUpperCase());
  }
  if (S.x_label) {
    svg.append("text").attr("x", m.l + iw / 2).attr("y", H - 14).attr("text-anchor", "middle")
      .attr("font-size", 14).attr("letter-spacing", "0.12em").attr("fill", "{{ brown_dim }}")
      .text(S.x_label.toUpperCase());
  }

  document.getElementById("chart-ready").style.display = "block";
})();
</script>
</body>
</html>
