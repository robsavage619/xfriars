<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<style>
@font-face {
  font-family: "Big Shoulders Display";
  src: url("file://{{ big_shoulders_ttf }}") format("truetype");
  font-weight: 400;
}
@font-face {
  font-family: "Space Grotesk";
  src: url("file://{{ space_grotesk_ttf }}") format("truetype");
  font-weight: 100 900;
}
/* keep Barlow for small-caps utility classes only */
@font-face {
  font-family: "Barlow Condensed";
  src: url("file://{{ barlow_semibold_ttf }}") format("truetype");
  font-weight: 600;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  width: 800px;
  height: 450px;
  overflow: hidden;
  background: {{ paper }};
}

/* ── Card shell ─────────────────────────────────────────────────────── */
.card {
  width: 800px;
  height: 450px;
  display: flex;
  flex-direction: column;
  background: {{ paper }};
  border-top: 4px solid {{ brown }};
  font-family: "Space Grotesk", sans-serif;
  color: {{ ink }};
}

/* ── Header ─────────────────────────────────────────────────────────── */
.header {
  position: relative;
  padding: 14px 24px 10px;
  border-bottom: 1px solid {{ hairline }};
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-shrink: 0;
}

.header-left { min-width: 0; }

.kicker {
  font-family: "Space Grotesk", sans-serif;
  font-weight: 600;
  font-size: 10px;
  color: {{ brown_dim }};
  letter-spacing: 0.26em;
  text-transform: uppercase;
  margin-bottom: 4px;
  white-space: nowrap;
}

.title {
  font-family: "Big Shoulders Display", sans-serif;
  font-weight: 800;
  font-size: 44px;
  line-height: 0.95;
  color: {{ ink }};
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.subtitle {
  font-family: "Space Grotesk", sans-serif;
  font-weight: 500;
  font-size: 11px;
  color: {{ text_secondary }};
  margin-top: 5px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  white-space: nowrap;
}

.header-right {
  flex-shrink: 0;
  margin-left: 16px;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-start;
  gap: 4px;
}

.logo-img {
  height: 22px;
  width: auto;
  display: block;
}

.as-of {
  font-size: 10px;
  color: {{ text_muted }};
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.06em;
  white-space: nowrap;
  font-family: "Space Grotesk", sans-serif;
  text-transform: uppercase;
}

/* ── Table area ─────────────────────────────────────────────────────── */
.table-wrap {
  flex: 1;
  overflow: hidden;
  padding: 4px 24px 0;
}

table {
  width: 100%;
  border-collapse: collapse;
  table-layout: fixed;
}

/* column widths: rank | player | team | stat */
col.c-rank   { width: 54px; }
col.c-player { /* auto */ }
col.c-team   { width: 84px; }
col.c-stat   { width: 76px; }

thead tr {
  border-bottom: 1px solid {{ hairline }};
}

th {
  font-family: "Space Grotesk", sans-serif;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: {{ text_muted }};
  padding: 9px 6px 6px;
}

th.c-rank   { text-align: center;  padding-left: 10px; }
th.c-player { text-align: left; }
th.c-team   { text-align: center; }
th.c-stat   { text-align: right;   padding-right: 12px; }

/* ── Data rows ─────────────────────────────────────────────────────── */
tbody tr {
  border-bottom: 1px solid {{ hairline }};
}

tbody tr:last-child {
  border-bottom: none;
}

td {
  font-size: 15px;
  padding: 0 6px;
  color: {{ ink }};
  line-height: 1;
  height: 34px;
  vertical-align: middle;
}

td.c-rank {
  text-align: center;
  padding-left: 10px;
  color: {{ text_muted }};
  font-size: 12px;
  font-variant-numeric: tabular-nums;
}

td.c-player { text-align: left; }

td.c-team {
  text-align: center;
  color: {{ text_muted }};
  font-size: 12px;
  letter-spacing: 0.05em;
  white-space: nowrap;
}

td.c-stat {
  text-align: right;
  padding-right: 12px;
  font-variant-numeric: tabular-nums;
  font-weight: 500;
}

/* ── Highlight row (the Padre) ──────────────────────────────────────── */
tbody tr.highlight {
  background: linear-gradient(
    to right,
    rgba(201, 154, 46, 0.18) 0%,
    rgba(201, 154, 46, 0.07) 55%,
    transparent 100%
  ) !important;
}

/* gold left border via inset shadow — survives border-collapse */
tbody tr.highlight td.c-rank {
  box-shadow: inset 4px 0 0 0 {{ gold }};
  color: {{ ink }};
  font-weight: 700;
  font-size: 14px;
}

tbody tr.highlight td {
  font-weight: 600;
}

tbody tr.highlight td.c-team {
  color: {{ ink }};
  font-size: 14px;
  letter-spacing: 0.06em;
}

/* hero number: ink + larger (no glow; gold is the row edge) */
tbody tr.highlight td.c-stat {
  color: {{ ink }};
  font-size: 26px;
  font-weight: 700;
}

/* ── Footer ─────────────────────────────────────────────────────────── */
.footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 7px 24px;
  border-top: 1px solid {{ hairline }};
  flex-shrink: 0;
}

.source {
  font-family: "Space Grotesk", sans-serif;
  font-weight: 400;
  font-size: 10px;
  color: {{ text_muted }};
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

.handle {
  font-family: "Space Grotesk", sans-serif;
  font-size: 15px;
  font-weight: 700;
  color: {{ brown }};
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.tagline {
  font-family: "Space Grotesk", sans-serif;
  font-size: 10px;
  font-weight: 400;
  color: {{ text_muted }};
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

{% if is_projection %}
.projection-badge {
  display: inline-block;
  border: 1px solid {{ brown_dim }};
  color: {{ brown_dim }};
  font-family: "Space Grotesk", sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  padding: 1px 6px;
  text-transform: uppercase;
  margin-left: 8px;
  vertical-align: middle;
  opacity: 0.85;
}
{% endif %}
</style>
</head>
<body>
<div class="card">

  <div class="header">
    <div class="header-left">
      <div class="kicker">xFriars</div>
      <div class="title">{{ title }}{% if is_projection %}<span class="projection-badge">Projection</span>{% endif %}</div>
      {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}</div>
    <div class="header-right">
      <img class="logo-img" src="file://{{ xfriars_logo }}" alt="xFriars">
      <div class="as-of">{{ as_of }}</div>
    </div>
  </div>

  <div class="table-wrap">
    <table>
      <colgroup>
        {% for col in columns %}
          {% if loop.first %}<col class="c-rank">
          {% elif loop.index == 2 %}<col class="c-player">
          {% elif loop.last %}<col class="c-stat">
          {% else %}<col class="c-team">
          {% endif %}
        {% endfor %}
      </colgroup>
      <thead>
        <tr>
          {% for col in columns %}
          <th class="{% if loop.first %}c-rank{% elif loop.index == 2 %}c-player{% elif loop.last %}c-stat{% else %}c-team{% endif %}">{{ col }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in rows %}
        <tr{% if highlight_row is not none and loop.index0 == highlight_row %} class="highlight"{% endif %}>
          {% for cell in row %}
          <td class="{% if loop.first %}c-rank{% elif loop.index == 2 %}c-player{% elif loop.last %}c-stat{% else %}c-team{% endif %}">{{ cell }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <div class="footer">
    <span class="source">Source: {{ source }} · through {{ as_of }}</span>
    <span class="tagline"><span style="color:{{ brown_dim }};font-weight:600">@xFriars</span> · San Diego Baseball Intelligence</span>
  </div>

</div>
</body>
</html>
