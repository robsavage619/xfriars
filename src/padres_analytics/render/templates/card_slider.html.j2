<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<script src="file://{{ d3_js }}"></script>
<style>
@font-face {
  font-family: "Big Shoulders Display";
  src: url("file://{{ big_shoulders_ttf }}") format("truetype");
  font-weight: 400 900;
}
@font-face {
  font-family: "Space Grotesk";
  src: url("file://{{ space_grotesk_ttf }}") format("truetype");
  font-weight: 100 900;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html, body {
  width: 540px;
  height: 675px;
  overflow: hidden;
  background: {{ bg_deep }};
}

.card {
  width: 540px;
  height: 675px;
  display: flex;
  flex-direction: column;
  background: radial-gradient(ellipse 120% 60% at 50% -5%, #241a12 0%, #14100c 64%);
  font-family: "Space Grotesk", sans-serif;
  color: {{ text_primary }};
}

.header {
  padding: 24px 30px 14px;
  border-bottom: 1px solid rgba(255, 196, 37, 0.30);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  flex-shrink: 0;
}
.kicker {
  font-weight: 600; font-size: 12px; color: {{ gold }};
  letter-spacing: 0.26em; text-transform: uppercase; margin-bottom: 6px;
}
.title {
  font-family: "Big Shoulders Display", sans-serif;
  font-weight: 900; font-size: 42px; line-height: 0.94; color: #FFFFFF;
  letter-spacing: 0.04em; text-transform: uppercase;
}
.subtitle {
  font-size: 12px; color: {{ text_secondary }}; margin-top: 6px;
  letter-spacing: 0.14em; text-transform: uppercase;
}
.header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; flex-shrink: 0; margin-left: 16px; }
.logo-img { height: 32px; width: auto; opacity: 0.92; }
.as-of {
  font-size: 11px; color: {{ text_secondary }}; opacity: 0.65;
  letter-spacing: 0.08em; text-transform: uppercase; font-variant-numeric: tabular-nums;
}

.chart-area { flex: 1; overflow: hidden; position: relative; }

.footer {
  display: flex; justify-content: space-between; align-items: center;
  padding: 12px 30px 18px; border-top: 1px solid rgba(255, 255, 255, 0.07); flex-shrink: 0;
}
.source { font-size: 10px; color: {{ text_secondary }}; opacity: 0.55; letter-spacing: 0.1em; text-transform: uppercase; }
.handle { font-size: 16px; font-weight: 700; color: {{ gold }}; letter-spacing: 0.14em; text-transform: uppercase; }
.tagline { font-size: 10px; color: {{ text_secondary }}; opacity: 0.4; letter-spacing: 0.14em; text-transform: uppercase; }
</style>
</head>
<body>
<div class="card">

  <div class="header">
    <div class="header-left">
      <div class="kicker">xFriars · Statcast</div>
      <div class="title">{{ title }}</div>
      {% if subtitle %}<div class="subtitle">{{ subtitle }}</div>{% endif %}
    </div>
    <div class="header-right">
      <img class="logo-img" src="file://{{ xfriars_logo }}" alt="xFriars">
      <div class="as-of">{{ as_of }}</div>
    </div>
  </div>

  <div class="chart-area" id="chart-area"></div>

  <div class="footer">
    <span class="source">Source: {{ source }} · percentile vs MLB</span>
    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:1px">
      <span class="handle">@xFriars</span>
      <span class="tagline">San Diego Baseball Intelligence</span>
    </div>
  </div>
</div>

<div id="chart-ready" style="display:none"></div>

<script>
(function() {
  const DS    = {{ dataset | safe }};
  const GOLD  = "{{ gold }}";
  const TEXTP = "{{ text_primary }}";
  const TEXTS = "{{ text_secondary }}";

  // Resolve role columns: one dimension (metric label) + one measure (0-100 percentile)
  const dimIdx = DS.columns.findIndex(c => c.role === "dimension");
  const valIdx = DS.columns.findIndex(c => c.role === "measure");
  const data = DS.rows.map(r => ({ label: String(r[dimIdx]), pct: +r[valIdx] }));

  const ordinal = n => {
    const i = Math.round(n);
    if (i % 100 >= 11 && i % 100 <= 13) return i + "th";
    return i + (["th","st","nd","rd","th","th","th","th","th","th"][i % 10]);
  };

  const container = document.getElementById("chart-area");
  const W = container.offsetWidth  || 540;
  const H = container.offsetHeight || 480;

  const padL = 30, padR = 30, labelW = 150, valueW = 58;
  const trackX = padL + labelW;
  const trackW = W - trackX - valueW - padR;

  const n = data.length;
  const rowH = Math.floor(H / n);
  const dotR = Math.min(11, Math.floor(rowH * 0.30));

  const x = d3.scaleLinear().domain([0, 100]).range([trackX, trackX + trackW]);

  const svg = d3.select("#chart-area").append("svg").attr("width", W).attr("height", H);

  const defs = svg.append("defs");
  const grad = defs.append("linearGradient").attr("id", "fill")
    .attr("x1", "0%").attr("y1", "0%").attr("x2", "100%").attr("y2", "0%");
  grad.append("stop").attr("offset", "0%").attr("stop-color", GOLD).attr("stop-opacity", 0.20);
  grad.append("stop").attr("offset", "100%").attr("stop-color", GOLD).attr("stop-opacity", 0.85);
  const glow = defs.append("filter").attr("id", "glow")
    .attr("x", "-80%").attr("y", "-80%").attr("width", "260%").attr("height", "260%");
  glow.append("feGaussianBlur").attr("in", "SourceGraphic").attr("stdDeviation", "4").attr("result", "b");
  const m = glow.append("feMerge");
  m.append("feMergeNode").attr("in", "b");
  m.append("feMergeNode").attr("in", "SourceGraphic");

  const rows = svg.selectAll(".row").data(data).join("g")
    .attr("transform", (d, i) => `translate(0, ${i * rowH})`);

  const cy = rowH / 2;

  // Metric label
  rows.append("text")
    .attr("x", padL).attr("y", cy).attr("dy", "0.35em")
    .attr("font-family", "Space Grotesk, sans-serif")
    .attr("font-size", 13).attr("font-weight", 600)
    .attr("fill", TEXTP).attr("fill-opacity", 0.9)
    .attr("letter-spacing", "0.04em")
    .text(d => d.label);

  // Track background
  rows.append("rect")
    .attr("x", trackX).attr("y", cy - 4).attr("width", trackW).attr("height", 8)
    .attr("rx", 4).attr("fill", "rgba(255,255,255,0.08)");

  // 50th-percentile (league average) tick
  rows.append("line")
    .attr("x1", x(50)).attr("x2", x(50)).attr("y1", cy - 10).attr("y2", cy + 10)
    .attr("stroke", "rgba(255,255,255,0.18)").attr("stroke-width", 1).attr("stroke-dasharray", "2 2");

  // Filled portion
  rows.append("rect")
    .attr("x", trackX).attr("y", cy - 4)
    .attr("width", d => Math.max(x(d.pct) - trackX, 2)).attr("height", 8)
    .attr("rx", 4).attr("fill", "url(#fill)");

  // Thumb dot
  rows.append("circle")
    .attr("cx", d => x(d.pct)).attr("cy", cy).attr("r", dotR)
    .attr("fill", GOLD).attr("filter", "url(#glow)");

  // Percentile value
  rows.append("text")
    .attr("x", W - padR).attr("y", cy).attr("dy", "0.35em").attr("text-anchor", "end")
    .attr("font-family", "Space Grotesk, sans-serif")
    .attr("font-size", 15).attr("font-weight", 700).attr("fill", GOLD)
    .attr("font-variant-numeric", "tabular-nums")
    .text(d => ordinal(d.pct));

  // Hairline separators
  rows.filter((d, i) => i < n - 1).append("line")
    .attr("x1", padL).attr("x2", W - padR).attr("y1", rowH).attr("y2", rowH)
    .attr("stroke", "rgba(255,255,255,0.05)").attr("stroke-width", 1);

  document.getElementById("chart-ready").style.display = "block";
})();
</script>
</body>
</html>
