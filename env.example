# Copy to .env and fill in real values. .env is gitignored.

# ── Database paths ─────────────────────────────────────────────────────────────
PADRES_DB_PATH=data/duckdb/padres.db
# Absolute path to savage-trade-evaluator's trades.db (attached read-only)
PADRES_TRADES_DB_PATH=/path/to/savage-trade-evaluator/data/duckdb/trades.db

# ── X / Twitter API credentials (phase 3) ─────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_BEARER_TOKEN=

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
